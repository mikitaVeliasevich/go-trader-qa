{
  "version": 2,
  "metrics": [
    {"tsv": "ws_messages", "expvar": "ws_messages_received"},
    {"tsv": "bus_drops", "expvar": "bus_drops"},
    {"tsv": "bus_publishes", "expvar": "bus_publishes"},
    {"tsv": "ticker_parsed", "expvar": "ticker_messages_parsed"},
    {"tsv": "private_parsed", "expvar": "private_messages_parsed"},
    {"tsv": "kline_parsed", "expvar": "kline_messages_parsed"},
    {"tsv": "order_create_ok", "expvar": "order_create_ok"},
    {"tsv": "order_amend_ok", "expvar": "order_amend_ok"},
    {"tsv": "order_cancel_ok", "expvar": "order_cancel_ok"},
    {"tsv": "order_filter_cancel", "expvar": "order_filter_cancel"},
    {"tsv": "order_create_blocked_position", "expvar": "order_create_blocked_position"},
    {"tsv": "position_opened", "expvar": "position_opened"},
    {"tsv": "position_reset", "expvar": "position_reset"},
    {"tsv": "position_reset_sl", "expvar": "position_reset_sl"},
    {"tsv": "position_reset_tp", "expvar": "position_reset_tp"},
    {"tsv": "position_reset_cancel", "expvar": "position_reset_cancel"},
    {"tsv": "position_reset_other", "expvar": "position_reset_other"},
    {"tsv": "algo_paused", "expvar": "algo_paused"},
    {"tsv": "algo_resumed_ok", "expvar": "algo_resumed_ok"},
    {"tsv": "order_fail_create", "expvar": "order_fail_create"},
    {"tsv": "order_fail_amend", "expvar": "order_fail_amend"},
    {"tsv": "order_fail_cancel", "expvar": "order_fail_cancel"},
    {"tsv": "order_fail_ret_10003", "expvar": "order_fail_ret_10003"},
    {"tsv": "order_fail_ret_10006", "expvar": "order_fail_ret_10006"},
    {"tsv": "order_fail_ret_10001", "expvar": "order_fail_ret_10001"},
    {"tsv": "order_fail_ret_10016", "expvar": "order_fail_ret_10016"},
    {"tsv": "order_fail_ret_110001", "expvar": "order_fail_ret_110001"},
    {"tsv": "order_fail_ret_110007", "expvar": "order_fail_ret_110007"},
    {"tsv": "order_fail_ret_110013", "expvar": "order_fail_ret_110013"},
    {"tsv": "order_fail_ret_110021", "expvar": "order_fail_ret_110021"},
    {"tsv": "order_fail_ret_110090", "expvar": "order_fail_ret_110090"},
    {"tsv": "order_fail_ret_110094", "expvar": "order_fail_ret_110094"},
    {"tsv": "order_fail_ret_110059", "expvar": "order_fail_ret_110059"},
    {"tsv": "order_fail_ret_110123", "expvar": "order_fail_ret_110123"},
    {"tsv": "order_fail_ret_110126", "expvar": "order_fail_ret_110126"},
    {"tsv": "algo_stopped_permanent", "expvar": "algo_stopped_permanent"},
    {"tsv": "risk_limit_margin_reduced", "expvar": "risk_limit_margin_reduced"},
    {"tsv": "tp_missing_create_ok", "expvar": "tp_missing_create_ok"},
    {"tsv": "tp_missing_create_fail", "expvar": "tp_missing_create_fail"},
    {"tsv": "tp_missing_close_position", "expvar": "tp_missing_close_position"},
    {"tsv": "sl_setup_started", "expvar": "sl_setup_started"},
    {"tsv": "sl_setup_ok", "expvar": "sl_setup_ok"},
    {"tsv": "sl_setup_fail", "expvar": "sl_setup_fail"},
    {"tsv": "sl_setup_cancelled", "expvar": "sl_setup_cancelled"},
    {"tsv": "sl_price_past_immediate_close", "expvar": "sl_price_past_immediate_close"},
    {"tsv": "partial_tp_needs_cancel", "expvar": "partial_tp_needs_cancel"},
    {"tsv": "position_reset_liquidation", "expvar": "position_reset_liquidation"},
    {"tsv": "position_reset_manual", "expvar": "position_reset_manual"},
    {"tsv": "price_wake_signals", "expvar": "price_wake_signals"},
    {"tsv": "price_exec_runs", "expvar": "price_exec_runs"},
    {"tsv": "private_order_wake_signals", "expvar": "private_order_wake_signals"},
    {"tsv": "private_order_events_signaled", "expvar": "private_order_events_signaled"},
    {"tsv": "private_order_drain_batches", "expvar": "private_order_drain_batches"},
    {"tsv": "private_order_events_drained", "expvar": "private_order_events_drained"}
  ],
  "log_patterns": [
    {"column": "connection_lost", "pattern": "connection lost|Connection lost|public.*disconnect"},
    {"column": "reconnected", "pattern": "reconnected|Reconnected|resubscribe"},
    {"column": "reconnect_failed", "pattern": "reconnect failed|Reconnect failed"},
    {"column": "errors_10003", "pattern": "retCode=10003|retCode\":10003"},
    {"column": "order_failures", "pattern": "Order (create|amend|cancel) failed"}
  ],
  "gates": [
    {"id": "G1", "rule": "bus_drops delta == 0"},
    {"id": "G2", "rule": "no retCode=10003 in soak.log"},
    {"id": "G3", "rule": "order_filter_cancel > 0 OR resting_proxy <= 30"},
    {"id": "G4", "rule": "position lifecycle consistent"},
    {"id": "G5", "rule": "order_create_ok >= 85% of position_reset"},
    {"id": "G6", "rule": "position_reset <= position_opened + 1"},
    {"id": "G7", "rule": "algo pause/resume pairing"},
    {"id": "G8", "rule": "algo_stopped_permanent delta == 0"},
    {"id": "G9", "rule": "order_fail_ret_10003 delta == 0"},
    {"id": "G10", "rule": "position_reset breakdown sums when reset > 0"},
    {"id": "G11", "rule": "reconnect_failed == 0 AND connection_lost <= reconnected + 1"},
    {"id": "G12", "rule": "tp_missing_create_fail == 0 AND tp_missing_close_position == 0"},
    {"id": "G13", "rule": "sl_setup_fail == 0 AND sl_price_past_immediate_close == 0"},
    {"id": "G14", "rule": "partial_tp_needs_cancel <= order_cancel_ok when active"},
    {"id": "G15", "rule": "order_fail_total == 0"},
    {"id": "G16", "rule": "wake path health when signals/positions active"}
  ],
  "profiles": {
    "wss-only": ["G1", "G2", "G11"],
    "lifecycle": ["G1", "G2", "G3", "G4", "G5", "G6", "G7"],
    "lifecycle-strict": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10", "G11", "G12", "G13", "G14", "G15", "G16"],
    "tpsl-health": ["G10", "G12", "G13", "G14"]
  }
}
